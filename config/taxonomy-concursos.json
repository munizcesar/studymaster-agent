  "filterMapping": {
    "description": "Mapeamento UI filtro → configuração interna",
    "concursos": {
      "portugues": {
        "internalKey": "concursos_portugues",
        "vectorizeCollection": "concursos_portugues",
        "fallbackMode": "generic_portuguese",
        "minContextLength": 200,
        "description": "Português para concursos"
      },
      "direito_constitucional": {
        "internalKey": "concursos_direito_constitucional",
        "vectorizeCollection": "concursos_direito_constitucional",
        "fallbackMode": "generic_law",
        "minContextLength": 300,
        "description": "Direito Constitucional"
      },
      "raciocinio_logico": {
        "internalKey": "concursos_raciocinio_logico",
        "vectorizeCollection": "concursos_raciocinio_logico",
        "fallbackMode": "generic_logic",
        "minContextLength": 150,
        "description": "Raciocínio Lógico"
      },
      "informatica": {
        "internalKey": "concursos_informatica",
        "vectorizeCollection": "concursos_informatica",
        "fallbackMode": "generic_it",
        "minContextLength": 250,
        "description": "Informática"
      },
      "administracao_publica": {
        "internalKey": "concursos_administracao_publica",
        "vectorizeCollection": "concursos_administracao_publica",
        "fallbackMode": "generic_admin",
        "minContextLength": 300,
        "description": "Administração Pública"
      }
    }
  },

  "validationRules": {
    "description": "Regras de validação pós-geração",
    "requiredFields": [
      "statement",
      "options",
      "correctAnswer",
      "explanation"
    ],
    "optionalFields": [
      "conceptualBasis",
      "source",
      "difficulty"
    ],
    "antiHallucination": {
      "forbiddenPatterns": [
        "banca",
        "concurso real",
        "prova de",
        "ano de",
        "edital"
      ],
      "action": "remove_or_normalize"
    },
    "answerValidation": {
      "optionsCount": {
        "min": 4,
        "max": 5,
        "lettersAllowed": ["A", "B", "C", "D", "E"]
      },
      "correctAnswerMustBe": "oneOfAbove"
    }
  },

  "fallbackBehaviors": {
    "description": "Comportamento quando contexto é insuficiente",
    "insufficientContext": {
      "threshold": "minContextLength não atingido",
      "behavior": "generic_question",
      "message": "Base conceitual indisponível no momento. Exibindo questão genérica.",
      "disclosureRequired": true
    },
    "collectionNotFound": {
      "behavior": "friendly_message",
      "message": "Desculpe, ainda não temos base de dados suficiente para {subject}. Tente novamente em breve!",
      "disclosureRequired": true
    }
  }
}
