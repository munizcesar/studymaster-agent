  "validationRules": {
    "description": "Regras de validação pós-geração",
    "requiredFields": [
      "statement",
      "options",
      "correctAnswer",
      "explanation"
    ],
    "optionalFields": [
      "conceptualBasis",
      "source",
      "difficulty"
    ],
    "antiHallucination": {
      "forbiddenPatterns": [
        "banca",
        "concurso real",
        "prova de",
        "ano de",
        "edital"
      ],
      "action": "remove_or_normalize"
    },
    "answerValidation": {
      "optionsCount": {
        "min": 4,
        "max": 5,
        "lettersAllowed": ["A", "B", "C", "D", "E"]
      },
      "correctAnswerMustBe": "oneOfAbove"
    }
  },

  "fallbackBehaviors": {
    "description": "Comportamento quando contexto é insuficiente",
    "insufficientContext": {
      "threshold": "minContextLength não atingido",
      "behavior": "generic_question",
      "message": "Base conceitual indisponível no momento. Exibindo questão genérica.",
      "disclosureRequired": true
    },
    "collectionNotFound": {
      "behavior": "friendly_message",
      "message": "Desculpe, ainda não temos base de dados suficiente para {subject}. Tente novamente em breve!",
      "disclosureRequired": true
    }
  }
}
